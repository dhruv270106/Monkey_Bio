# Meta / Instagram App Credentials
# Get these from https://developers.facebook.com/
NEXT_PUBLIC_INSTAGRAM_APP_ID=your_app_id_here
INSTAGRAM_APP_SECRET=your_app_secret_here

# The redirect URI must match what you set in Meta App settings
# For production, change to: https://yourdomain.com/auth/instagram/callback
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=http://localhost:3000/auth/instagram/callback
